# APP
APP_NAME="BCN Last Minute"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://last24bcn.daw.inspedralbes.cat
APP_KEY=base64:PLACEHOLDER_GENERATED_BY_ARTISAN

# DB (Docker Internal)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=ultimahorabcn_db
DB_USERNAME=root
DB_PASSWORD=password

# Ports (Multi-tenant)
# Access the app via https://last24bcn.daw.inspedralbes.cat
# Internal mapping: 8005 -> 8000, 3005 -> 3001, 5005 -> 5173

# GOOGLE OAUTH
GOOGLE_CLIENT_ID=PLACEHOLDER
GOOGLE_CLIENT_SECRET=PLACEHOLDER
GOOGLE_REDIRECT_URI=https://last24bcn.daw.inspedralbes.cat/api/auth/google/callback

# MAIL
MAIL_MAILER=smtp
MAIL_HOST=PLACEHOLDER
MAIL_PORT=587
MAIL_USERNAME=PLACEHOLDER
MAIL_PASSWORD=PLACEHOLDER
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=PLACEHOLDER
MAIL_FROM_NAME="${APP_NAME}"
