server {
    server_name last24bcn.daw.inspedralbes.cat;

    # Frontend (Estàtic)
    root /var/www/last24bcn/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # API Backend (Laravel)
    location /api {
        proxy_pass http://127.0.0.1:8005;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Realtime (Socket.io)
    location /socket.io {
        proxy_pass http://127.0.0.1:3005;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;

        # Stability
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    # Realtime Admin State
    location /admin/state {
        proxy_pass http://127.0.0.1:3005/admin/state;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/last24bcn.daw.inspedralbes.cat/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/last24bcn.daw.inspedralbes.cat/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = last24bcn.daw.inspedralbes.cat) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name last24bcn.daw.inspedralbes.cat;
    return 404; # managed by Certbot
}
